{
  "name": "feishu-wechat-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bridge Feishu Base records to WeChat Official Account drafts through lark-cli.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "pm2:dev": "pm2 start ecosystem.config.cjs --only wechat-article-pilot-dev",
    "pm2:dev:restart": "pm2 restart wechat-article-pilot-dev",
    "pm2:dev:logs": "pm2 logs wechat-article-pilot-dev",
    "pm2:dev:stop": "pm2 stop wechat-article-pilot-dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
